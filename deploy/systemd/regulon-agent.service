[Unit]
Description=Regulon Live Regulatory Ingestion Agent
After=network.target
Wants=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/regulon
Environment=NODE_ENV=production
Environment=ALERT_AGENT_PORT=8787
EnvironmentFile=/etc/regulon/regulon-agent.env
ExecStart=/usr/bin/node /opt/regulon/index.js
Restart=always
RestartSec=5
TimeoutStartSec=30
TimeoutStopSec=30
StandardOutput=append:/var/log/regulon-agent/out.log
StandardError=append:/var/log/regulon-agent/err.log

[Install]
WantedBy=multi-user.target
