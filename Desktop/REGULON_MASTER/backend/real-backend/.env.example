# SANNIDH CA Dashboard - Real Backend Environment Configuration
# Copy this to .env and update with your actual values

# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Supabase Configuration (Primary Database)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# PostgreSQL Configuration (Fallback/Local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sannidh_ca_dashboard
DB_USER=sannidh_user
DB_PASSWORD=sannidh_password

# Redis Configuration (Caching & Sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_32_characters
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_key
REFRESH_TOKEN_EXPIRE=30d

# OpenAI Configuration (AI Drafting Engine)
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# Government API Integration Keys
GSTN_API_KEY=your_gstn_api_key
GSTN_API_SECRET=your_gstn_api_secret
MCA_API_KEY=your_mca_api_key
INCOME_TAX_API_KEY=your_income_tax_api_key

# Third-party Service Integration
SETU_API_KEY=your_setu_api_key
KARZA_API_KEY=your_karza_api_key
PERFIOS_API_KEY=your_perfios_api_key

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Notification Services
# Twilio (WhatsApp & SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Email Service (Nodemailer with Gmail)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=SANNIDH CA Dashboard <noreply@sannidh.com>

# File Storage
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,doc,docx,xls,xlsx
STORAGE_PATH=./uploads

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=your_session_secret_key

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=7

# Development/Testing
ENABLE_MOCK_DATA=true
MOCK_GOVERNMENT_APIs=true
DEBUG_MODE=true

# Production Settings (Set to false in production)
ENABLE_CORS=true
ENABLE_SWAGGER=true
ENABLE_DEBUG_ROUTES=true

# Monitoring & Analytics
ENABLE_ANALYTICS=true
ANALYTICS_API_KEY=your_analytics_key

# Government Portal URLs (For data scraping)
GST_PORTAL_URL=https://services.gst.gov.in
MCA_PORTAL_URL=https://www.mca.gov.in
INCOME_TAX_URL=https://www.incometax.gov.in
SEBI_URL=https://www.sebi.gov.in
RBI_URL=https://www.rbi.org.in
CBIC_URL=https://www.cbic.gov.in
EGAZETTE_URL=https://egazette.gov.in